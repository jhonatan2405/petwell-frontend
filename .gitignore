# ==========================================
# Frontend Project (Next.js / Node.js)
# ==========================================

# 1. Dependencias (Dependencias)
# ------------------------------------------
/node_modules/
/.pnp/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# 2. Archivos Sensibles y Variables de Entorno (Secrets & .env)
# ------------------------------------------
# Ignorar todos los archivos de entorno
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
# Archivos de claves o certificados
*.pem
*.key
*.cert
*.crt
# Archivos de credenciales en texto plano
secrets.json
credentials.json

# 3. Logs y Archivos de Depuración (Logs & Debugging)
# ------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
*.pid
*.seed
*.pid.lock

# 4. Archivos de Compilación y Producción (Build Artifacts)
# ------------------------------------------
# Next.js
/.next/
/out/
# Otras carpetas comunes de compilación
/dist/
/build/
.cache/
.swc/

# 5. Testing y Cobertura (Testing & Coverage)
# ------------------------------------------
/coverage/
.nyc_output/

# 6. Archivos Generados por el Sistema Múltiple (System Files)
# ------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.cab
*.msi
*.msm
*.msp
*.lnk
$RECYCLE.BIN/
desktop.ini

# 7. Configuraciones de Editores e IDEs (IDEs & Editors)
# ------------------------------------------
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
# IntelliJ / WebStorm (JetBrains)
.idea/
*.iws
*.iml
*.ipr
# Otros
.nova/
.zed/
.fleet/

# 8. Tipado y Herramientas (TS & Tooling)
# ------------------------------------------
*.tsbuildinfo
next-env.d.ts

# 9. Herramientas de Despliegue y Nube (Deployment & Cloud)
# ------------------------------------------
.vercel/
.netlify/
.serverless/
